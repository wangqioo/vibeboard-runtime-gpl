    },
    {
      "upstreamId": "photos",
      "targetId": "holocubic_photos",
      "phase": 3,
      "status": "blocked",
      "requiredRuntime": ["input", "lvgl-canvas", "image-decoders"],
      "notes": "Needs media decoding, canvas image draw, and key/touch navigation."
    },
    {
      "upstreamId": "plane",
      "targetId": "holocubic_plane",
      "phase": 3,
      "status": "blocked",
      "requiredRuntime": ["input", "image-decoders", "lvgl-animation"],
      "notes": "Large game with many assets; start later with simplified controls and strict object budget."
    },
    {
      "upstreamId": "settings",
      "targetId": "holocubic_settings",
      "phase": 3,
      "status": "blocked",
      "requiredRuntime": ["input", "app-manager"],
