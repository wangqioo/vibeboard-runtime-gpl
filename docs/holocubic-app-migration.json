      "notes": "Needs GIF/video decode and navigation controls."
    },
    {
      "upstreamId": "voice_ai",
      "targetId": "voice_ai",
      "phase": 5,
      "status": "blocked",
      "requiredRuntime": ["audio", "http-callback", "bridge-config"],
      "notes": "Already copied locally; full upstream behavior needs audio/I2S and bridge hardening."
    },
    {
      "upstreamId": "weather",
      "targetId": "weather",
      "phase": 1,
      "status": "planned",
      "requiredRuntime": ["network", "time-compat", "image-decoders"],
      "notes": "Already has a curated local port; re-sync after time/image compatibility decisions."
    }
  ]
}
