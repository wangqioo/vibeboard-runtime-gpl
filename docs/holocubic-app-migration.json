      "notes": "Interactive tile game; migrate after Lua key/touch events and animation cleanup exist."
    },
    {
      "upstreamId": "BTC",
      "targetId": "holocubic_btc",
      "phase": 2,
      "status": "planned",
      "requiredRuntime": ["lvgl-canvas", "http-callback", "time-compat"],
      "notes": "Start as a display-only price/status screen after canvas and HTTP compatibility work."
    },
    {
      "upstreamId": "ConwayLife",
      "targetId": "holocubic_conway_life",
      "phase": 2,
      "status": "planned",
      "requiredRuntime": ["lvgl-canvas"],
      "notes": "Good screensaver candidate once canvas rectangle drawing is board-verified."
    },
    {
      "upstreamId": "FluidPendant",
      "targetId": "holocubic_fluid_pendant",
      "phase": 2,
      "status": "planned",
      "requiredRuntime": ["lvgl-canvas", "time-compat"],
      "notes": "Timer-driven visual app; needs canvas before full-fidelity migration."
    },
    {
      "upstreamId": "MatrixRain",
      "targetId": "holocubic_matrix_rain",
      "phase": 2,
      "status": "planned",
      "requiredRuntime": ["lvgl-canvas"],
      "notes": "Fast visual win after canvas text/rectangle drawing is available."
    },
    {
      "upstreamId": "NixieClock",
      "targetId": "holocubic_nixie_clock",
      "phase": 1,
      "status": "ported",
