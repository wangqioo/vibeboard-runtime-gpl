      "notes": "Compat port recreates the Nixie clock style with safe LVGL objects instead of PNG assets."
    },
    {
      "upstreamId": "Spectrum",
      "targetId": "holocubic_spectrum",
      "phase": 3,
      "status": "blocked",
      "requiredRuntime": ["native-spectrum", "input", "lvgl-extra"],
      "notes": "Depends on spectrum/audio-style runtime work; defer until input and native policy are stable."
    },
    {
      "upstreamId": "clock",
      "targetId": "holocubic_analog_clock",
      "phase": 1,
      "status": "ported",
      "requiredRuntime": ["lvgl", "timer"],
      "notes": "Compat port recreates an analog clock face with safe LVGL objects instead of PNG hands."
    },
    {
