    {
      "upstreamId": "devtools",
      "targetId": "holocubic_devtools",
      "phase": 4,
      "status": "blocked",
      "requiredRuntime": ["app-service", "web-routes", "file-management"],
      "notes": "Service-style tool; migrate only after sandboxed app-owned routes and file APIs exist."
    },
    {
      "upstreamId": "hwmon",
      "targetId": "holocubic_hwmon",
      "phase": 2,
      "status": "planned",
      "requiredRuntime": ["http-callback", "lvgl-canvas"],
      "notes": "Can start display-only, then enable host bridge mode in a later service/network phase."
    },
    {
      "upstreamId": "lv-benchmark",
      "targetId": "holocubic_lv_benchmark",
      "phase": 6,
      "status": "blocked",
      "requiredRuntime": ["lvgl-broad-surface", "benchmark-metrics"],
      "notes": "Useful after the runtime intentionally supports the LVGL features it measures."
    },
    {
      "upstreamId": "mini_claw",
      "targetId": "holocubic_mini_claw",
      "phase": 5,
      "status": "blocked",
      "requiredRuntime": ["app-service", "http-callback", "bridge-config"],
      "notes": "Bridge app; defer until service and network callback contracts are defined."
