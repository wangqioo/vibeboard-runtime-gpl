{
  "schema": "vibeboard-holocubic-migration@1",
  "source": {
    "repo": "https://github.com/clocteck/holocubic-apps.git",
    "commit": "78da33f",
    "localMirror": "upstream/holocubic-apps"
  },
  "apps": [
